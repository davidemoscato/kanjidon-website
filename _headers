# Security headers
/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()

# Cache static assets aggressively (fonts, images, CSS, JS)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Cache favicon and manifest
/favicon.ico
  Cache-Control: public, max-age=2592000
/site.webmanifest
  Cache-Control: public, max-age=2592000
/apple-touch-icon.png
  Cache-Control: public, max-age=2592000

# HTML pages - short cache, always revalidate
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# Root CSS/JS (no filename hashing) - revalidate so deploys take effect immediately
/styles.css
  Cache-Control: public, max-age=0, must-revalidate
/lang-banner.js
  Cache-Control: public, max-age=0, must-revalidate
/conversion.js
  Cache-Control: public, max-age=0, must-revalidate

# Conversion hand-off pages must never be cached or indexed
/go/*
  Cache-Control: no-store
  X-Robots-Tag: noindex, nofollow

# Sitemap and robots - moderate cache
/sitemap.xml
  Cache-Control: public, max-age=3600
/robots.txt
  Cache-Control: public, max-age=3600
